# Pause Reborn — API key 模板
# 把本文件复制为 backend/.env 并填入真实值。
# .env 已在 .gitignore,不会被提交。Mock 模式不需要任何 key。
#
# 说明:本项目所有 LLM / 图像 API 都走中转站,不直连官方。
# - LLM 中转站(Nova)兼容 OpenAI chat/completions 协议
# - 图像中转站也复用 chat/completions 接口,响应 content 是 Markdown 格式的图片链接
#   (例如 ![](https://...)),代码需自行从 Markdown 中提取 URL 并下载图片
# - ElevenLabs TTS 直连官方(无中转 base_url 约定)

# ─── LLM(Nova,Stage 2a 视觉理解 + Stage 2b 文本决策)───
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_VISION=
LLM_MODEL_TEXT=

# ─── 图像生成(中转站,Stage 2c)───
# ⚠️ 接口形态:POST $IMAGE_BASE_URL/chat/completions
# ⚠️ 响应解析:choices[0].message.content 是 Markdown,内含 ![](URL),需提取后下载
IMAGE_API_KEY=
IMAGE_BASE_URL=
IMAGE_MODEL=

# ─── ElevenLabs(Stage 4 TTS,直连官方)───
ELEVENLABS_API_KEY=

# ─── 可选:网络代理 ───
# httpx 默认 trust_env=True,会自动读取下列环境变量,代码无需特殊处理
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# ─── 真实 AI 调用开关 ───
# Stage 4 起恢复:false=三段全走 mock_responses/{frame_id}.json + 假等待节奏
#                  true =三段调真 API,失败时单段自动回落到 mock(响应 source=mock_fallback)
USE_REAL_AI=true

# ─── Mock 模式演示节奏倍率(USE_REAL_AI=false 时生效)───
# 三段基础假等待:scene=1.5s / decision=1.0s / image=2.0s,统一乘以本系数
# 演示加速:0.3 → 总等待约 1.3s;演示放慢:2.0 → 总等待约 9s
MOCK_DELAY_MULTIPLIER=1.0

# ─── 后端服务 ───
BACKEND_PORT=8000
