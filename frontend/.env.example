# ────────────────────────────────────────────────────────────
# Pause Reborn · 前端环境变量
# ────────────────────────────────────────────────────────────

# 部署模式开关
# true  = 完全使用预生成 Mock 数据(适合 Vercel 部署,前端独立运行)
# false = 调用真实后端 AI Pipeline(适合本地开发验证真实链路)
NEXT_PUBLIC_USE_HANDCRAFTED_ADS=false

# 真实后端地址(仅在 USE_HANDCRAFTED_ADS=false 时生效)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
