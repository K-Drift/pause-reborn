# Pause Reborn — API key 模板
# 把本文件复制为 .env 并填入真实 key。.env 已在 .gitignore 中,不会被提交。
#
# Stage 0/1 Mock 模式不需要任何 key。
# 接入真 API 时,Agent 会停下来问用户具体要哪个服务商,届时再补。

# ─── 第一段:VLM(场景理解)─── Stage 2a 启用
# 服务商待定(GPT-4o / Claude Vision / Gemini / 其他)
VLM_PROVIDER=
VLM_API_KEY=
VLM_MODEL=

# ─── 第二段:LLM(广告决策)─── Stage 2b 启用
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

# ─── 第三段:图像生成 ─── Stage 2c 启用
IMAGE_PROVIDER=
IMAGE_API_KEY=
IMAGE_MODEL=

# ─── TTS(对话追问语音)─── Stage 4 启用
# SPEC 偏好 ElevenLabs
TTS_PROVIDER=elevenlabs
TTS_API_KEY=

# ─── 后端服务 ───
BACKEND_PORT=8000
